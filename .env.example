# HELLCOIN Environment Variables
# Copy this file to .env.local and fill in your values

# Site URL (used for SEO and metadata)
NEXT_PUBLIC_SITE_URL=https://hellcoin.fun

# Buy link (Raydium swap URL with your token)
NEXT_PUBLIC_BUY_LINK=https://raydium.io/swap

# X (Twitter) profile URL
NEXT_PUBLIC_X_LINK=https://x.com/hellcoin666

# DEXScreener URL for your token
NEXT_PUBLIC_DEXSCREENER_LINK=https://dexscreener.com/solana/hellcoin

# Contract address (REQUIRED for production)
NEXT_PUBLIC_CONTRACT_ADDRESS=YOUR_CONTRACT_ADDRESS_HERE
